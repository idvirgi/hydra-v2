            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Lookup Etsy Shop": {
      "main": [
        [
          {
            "node": "Build Etsy OAuth State",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Etsy OAuth State": {
      "main": [
        [
          {
            "node": "Store Etsy OAuth State",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Store Etsy OAuth State": {
      "main": [
        [
          {
            "node": "OAuth Success Payload",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {},
  "versionId": "hydra-etsy-oauth-callback-v1"
}
